<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dev release flavor: allow cleartext HTTP traffic to local dev server -->
    <application
        android:usesCleartextTraffic="true">
        <!-- Avoid emulator black-screen issues seen with Impeller + OpenGLES. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />
    </application>
</manifest>
