# =============================================================================
# Sports Venue AI Chatbot - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# =============================================================================

# --- App Configuration ---
APP_NAME="Sports Venue AI Chatbot"
APP_VERSION="1.0.0"
APP_ENV="development"
DEBUG=false

# --- PostgreSQL ---
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/sports_venue"

# --- Neo4j ---
NEO4J_URI="bolt://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="password"
NEO4J_DATABASE="neo4j"

# --- Redis ---
REDIS_URL="redis://localhost:6379/0"
SESSION_TTL=3600

# --- LLM Providers ---
# Options: "google", "mimo", "ollama"
LLM_PROVIDER="google"

# Google Gemini
GEMINI_API_KEY=""
GOOGLE_API_KEY=""
LLM_MODEL="gemini-2.0-flash"

# Xiaomi MiMo (OpenAI-compatible)
MIMO_API_KEY=""
MIMO_API_BASE_URL=""
MIMO_MODEL="mimo-v2.5"

# Ollama (local fallback)
OLLAMA_FALLBACK_MODEL="alibayram/mimo-7b-rl"
OLLAMA_BASE_URL="http://localhost:11434"

# LLM Settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- Embedding ---
EMBEDDING_API_URL="http://localhost:11434/api/embeddings"
EMBEDDING_MODEL="nomic-embed-text"
KG_EMBEDDING_TIMEOUT_SECONDS=3
KG_EMBEDDING_FAILURE_COOLDOWN_SECONDS=60
KG_AUTO_EMBED_ON_STARTUP=true
KG_AUTO_EMBED_MAX_NODES=500

# --- Payment Service (gRPC) ---
PAYMENT_SERVICE_HOST="localhost"
PAYMENT_SERVICE_PORT="9090"
INTERNAL_API_KEY="change-me-to-random-32-chars"

# --- VNPay (for Java service) ---
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""

# --- Secret ---
SECRET_KEY="change-me-in-production"
