# =============================================================================
# Sports Venue AI Chatbot - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# =============================================================================

# --- App Configuration ---
APP_NAME="Sports Venue AI Chatbot"
APP_VERSION="1.0.0"
APP_ENV="development"
DEBUG=false

# --- PostgreSQL ---
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/sports_venue"

# --- Neo4j ---
NEO4J_URI="bolt://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="password"
NEO4J_DATABASE="neo4j"

# --- Redis ---
REDIS_URL="redis://localhost:6379/0"
SESSION_TTL=3600

# --- LLM Providers ---
# Options: "google", "mimo", "ollama"
LLM_PROVIDER="google"

# Google Gemini
GEMINI_API_KEY=""
GOOGLE_API_KEY=""
LLM_MODEL="gemini-2.0-flash"

# Xiaomi MiMo (OpenAI-compatible)
MIMO_API_KEY=""
MIMO_API_BASE_URL=""
MIMO_MODEL="mimo-v2.5"

# Ollama (local fallback)
OLLAMA_FALLBACK_MODEL="alibayram/mimo-7b-rl"
OLLAMA_BASE_URL="http://localhost:11434"

# LLM Settings
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- Embedding ---
EMBEDDING_MODEL="models/text-embedding-004"
EMBEDDING_DIMENSION=768

# --- Secret ---
SECRET_KEY="change-me-in-production"
